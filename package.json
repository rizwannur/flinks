{
  "name": "@rizwannur/flinks",
  "version": "0.1.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Community (unofficial) modern, fully-typed Flinks API client for Node.js and Bun — Connect, Authorize, Enrich, Identity, Upload, Pay, and Open Banking.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js",
      "require": "./dist/next.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:sandbox": "RUN_SANDBOX=1 vitest run tests/sandbox.test.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "prepublishOnly": "npm run build",
    "release:patch": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags"
  },
  "keywords": [
    "flinks",
    "banking",
    "fintech",
    "open-banking",
    "financial-data",
    "api-client",
    "typescript",
    "bun"
  ],
  "author": "Rafey",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rizwannur/flinks.git"
  },
  "homepage": "https://github.com/rizwannur/flinks#readme",
  "bugs": {
    "url": "https://github.com/rizwannur/flinks/issues"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
